{
  "name": "playwrigt-project",
  "version": "1.0.0",
  "description": "A simple Playwright test automation demo using TypeScript and Page Object Model pattern",
  "main": "index.js",
  "scripts": {
    "setup": "npm install && npx playwright install --with-deps chromium",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "report": "playwright show-report"
  },
  "keywords": [
    "playwright",
    "typescript",
    "automation",
    "testing",
    "page-object-model"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
